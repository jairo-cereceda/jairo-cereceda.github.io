---
import Subheading from './Subheading.astro';

interface CertificateImage {
  alt: string;
  src: string;
}

export interface CertificatesCarrouselData {
  images: CertificateImage[];
}

const { images } = Astro.props;
---

<section class="p-3 mt-3">
  <Subheading text="Otras Certificaciones" />

  <div class="group my-5 overflow-hidden whitespace-nowrap">
    {
      [1, 2, 3].map(() => (
        <div class="inline-block animate-scroll-left group-hover:[animation-play-state:paused]">
          {images.map(({ src, alt }: CertificateImage) => (
            <img
              height={200}
              src={src}
              alt={alt}
              class="ml-2 mt-2 inline-block w-[200px] max-w-none rounded-2xl shadow-[0_4px_10px_rgba(255,255,255,0.3)]"
            />
          ))}
        </div>
      ))
    }
  </div>
</section>
