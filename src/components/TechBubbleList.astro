---
import TechBubble, { type TechBubbleData } from './TechBubble.astro';

export interface Props {
  techs: TechBubbleData[];
}

const { techs } = Astro.props;
---

<div class="grid grid-cols-1 sm:grid-cols-2 p-3 mt-5 gap-4 js-tech-grid">
  {techs && techs.map((tech) => <TechBubble data={tech} />)}
</div>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initAnimation() {
    ScrollTrigger.getAll().forEach((t) => t.kill());

    const bubbles = document.querySelectorAll('.js-tech-bubble');

    gsap.set(bubbles, { opacity: 0, y: 30 });

    gsap.to(bubbles, {
      y: 0,
      opacity: 1,
      duration: 0.8,
      stagger: 0.1,
      ease: 'back.out(1.7)',
      scrollTrigger: {
        trigger: '.js-tech-grid',
        start: 'top 85%',
      },
    });
  }

  initAnimation();

  document.addEventListener('astro:page-load', initAnimation);
</script>
