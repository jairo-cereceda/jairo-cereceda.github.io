---
import GlassWrapper from './GlassWrapper.astro';
---

<GlassWrapper>
  <div class="flex justify-between items-center">
    <h2 class="text-2xl text-white">Mail</h2>
    <p
      id="form-status"
      role="alert"
      aria-live="polite"
      class="opacity-0 transition-opacity duration-300"
    >
    </p>
  </div>
  <form
    action="https://formspree.io/f/xeerlnjw"
    method="POST"
    id="contact-form"
    class="flex flex-col gap-2 text-white w-full"
  >
    <input type="hidden" name="_subject" value="Nuevo mensaje desde mi portfolio" />
    <input type="text" name="_gotcha" style="display:none" />

    <div class="flex-col gap-2 w-full items-center">
      <label for="name">Tu nombre:</label>
      <input
        type="text"
        name="name"
        id="name"
        required
        class="border border-white rounded-xl p-1 w-full"
      />
    </div>

    <div class="flex-col gap-2 w-full items-center">
      <label for="email">Tu correo:</label>
      <input
        type="email"
        name="_replyto"
        id="email"
        required
        class="border border-white rounded-xl p-1 w-full"
      />
    </div>

    <div class="flex-col gap-2 w-full items-center">
      <label for="message">Mensaje:</label>
      <textarea
        name="message"
        id="message"
        required
        class="border border-white rounded-xl p-1 w-full"></textarea>
    </div>

    <button
      type="submit"
      class="bg-brand rounded-full p-3 text-black font-bold hover:shadow-yellow-light transition-all duration-200 ease cursor-pointer"
      >Enviar</button
    >
  </form>
</GlassWrapper>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = document.getElementById('form-status') as HTMLParagraphElement | null;

  if (form && status) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const name = (form.elements.namedItem('name') as HTMLInputElement).value.trim();
      const email = (form.elements.namedItem('_replyto') as HTMLInputElement).value.trim();
      const message = (form.elements.namedItem('message') as HTMLTextAreaElement).value.trim();

      if (!name || !email || !message) {
        status.textContent = 'Completa todos los campos.';
        status.classList.add('text-red-400');
        status.classList.remove('opacity-0');
        return;
      }

      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!emailRegex.test(email)) {
        status.textContent = 'Ingresa un correo válido.';
        status.classList.add('text-red-400');
        status.classList.remove('opacity-0');
        return;
      }

      const data = new FormData(form);
      try {
        const res = await fetch('https://formspree.io/f/xeerlnjw', {
          method: 'POST',
          body: data,
          headers: { Accept: 'application/json' },
        });

        if (res.ok) {
          status.textContent = '¡Mensaje enviado, gracias!';
          status.classList.remove('opacity-0');
          status.classList.remove('text-red-400');
          status.classList.add('text-green-400');
          form.reset();
        } else {
          status.textContent = 'Hubo un error.';
          status.classList.remove('opacity-0');
          status.classList.remove('text-green-400');
          status.classList.add('text-red-400');
        }
      } catch (error) {
        status.textContent = 'Hubo un error de conexión.';
        status.classList.remove('opacity-0');
        status.classList.remove('text-green-400');
        status.classList.add('text-red-400');

        console.error('Error de conexión:', error);
      }
    });
  }
</script>
