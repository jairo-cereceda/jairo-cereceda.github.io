---
export interface Props {
  text: string;
}

const { text } = Astro.props;
---

<div>
  <div class="flex justify-center">
    <div class="h-0.5 w-25 bg-brand shadow-2xl"></div>
  </div>

  <div class="p-3">
    <h2 class="text-white text-2xl text-center">{text}</h2>
  </div>

  <div class="flex justify-center">
    <div class="h-0.5 w-25 bg-brand shadow-2xl"></div>
  </div>
</div>
